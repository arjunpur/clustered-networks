\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Distribution of firing rates for excitatory neurons in uniform and clustered networks. Both networks maintain low mean firing rates, though the clustered network shows a broader distribution reflecting the alternation between high and low activity states. Triangles indicate mean values.}}{2}{figure.caption.2}\protected@file@percent }
\newlabel{fig:firing_rates}{{2}{2}{Distribution of firing rates for excitatory neurons in uniform and clustered networks. Both networks maintain low mean firing rates, though the clustered network shows a broader distribution reflecting the alternation between high and low activity states. Triangles indicate mean values}{figure.caption.2}{}}
