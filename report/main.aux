\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Mean Fano factor as a function of counting window size. In the clustered network, the Fano factor increases with window size, reflecting slow rate fluctuations. The uniform network remains near the Poisson baseline (FF~=~1).}}{2}{figure.caption.4}\protected@file@percent }
\newlabel{fig:fano_vs_window}{{4}{2}{Mean Fano factor as a function of counting window size. In the clustered network, the Fano factor increases with window size, reflecting slow rate fluctuations. The uniform network remains near the Poisson baseline (FF~=~1)}{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Distribution of pairwise spike count correlations for all neuron pairs. Correlations remain centered near zero on average for both network types.}}{2}{figure.caption.5}\protected@file@percent }
\newlabel{fig:correlations_all}{{5}{2}{Distribution of pairwise spike count correlations for all neuron pairs. Correlations remain centered near zero on average for both network types}{figure.caption.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.5}Timescales}{2}{subsection.2.5}\protected@file@percent }
\newlabel{sec:timescales}{{2.5}{2}{Timescales}{subsection.2.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Distribution of pairwise spike count correlations for within-cluster pairs only. The clustered network shows a heavy positive tail that increases with counting window size (50~ms vs.\ 100~ms).}}{3}{figure.caption.6}\protected@file@percent }
\newlabel{fig:correlations_cluster}{{6}{3}{Distribution of pairwise spike count correlations for within-cluster pairs only. The clustered network shows a heavy positive tail that increases with counting window size (50~ms vs.\ 100~ms)}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Autocovariance as a function of lag for uniform and clustered networks. The clustered network shows slower decay, indicating longer intrinsic timescales.}}{3}{figure.caption.7}\protected@file@percent }
\newlabel{fig:autocovariance_timescales}{{7}{3}{Autocovariance as a function of lag for uniform and clustered networks. The clustered network shows slower decay, indicating longer intrinsic timescales}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Cross-covariance as a function of lag for uniform and clustered networks. Within-cluster pairs in the clustered network show slower decay, indicating stronger shared rate fluctuations.}}{3}{figure.caption.8}\protected@file@percent }
\newlabel{fig:crosscovariance_timescales}{{8}{3}{Cross-covariance as a function of lag for uniform and clustered networks. Within-cluster pairs in the clustered network show slower decay, indicating stronger shared rate fluctuations}{figure.caption.8}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.6}Stimulus-Dependent Variability}{3}{subsection.2.6}\protected@file@percent }
\newlabel{sec:stimulus_variability}{{2.6}{3}{Stimulus-Dependent Variability}{subsection.2.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Effect of stimulus on network dynamics. \textbf  {(a)} Clustered network activity with increased stimulus on the first cluster (first 80 neurons). \textbf  {(b)} Increased stimulation on the first cluster, uniform network. \textbf  {(c)} Fano factor as a function of time under input stimulus. The clustered network exhibits larger variability changes over time than the uniform network. \textbf  {(c)} Fano factor only in the stimulated cluster, only outside the cluster.}}{3}{figure.caption.9}\protected@file@percent }
\newlabel{fig:fano_time_stimulus}{{9}{3}{Effect of stimulus on network dynamics. \textbf {(a)} Clustered network activity with increased stimulus on the first cluster (first 80 neurons). \textbf {(b)} Increased stimulation on the first cluster, uniform network. \textbf {(c)} Fano factor as a function of time under input stimulus. The clustered network exhibits larger variability changes over time than the uniform network. \textbf {(c)} Fano factor only in the stimulated cluster, only outside the cluster}{figure.caption.9}{}}
