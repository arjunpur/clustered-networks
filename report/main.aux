\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Distribution of Fano factors across neurons for uniform and clustered networks. The clustered network exhibits a broader distribution with a higher mean (triangles), indicating greater spike count variability.}}{2}{figure.caption.3}\protected@file@percent }
\newlabel{fig:fano_distribution}{{3}{2}{Distribution of Fano factors across neurons for uniform and clustered networks. The clustered network exhibits a broader distribution with a higher mean (triangles), indicating greater spike count variability}{figure.caption.3}{}}
